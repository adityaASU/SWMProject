# ── LLM Backend ────────────────────────────────────────────────────────────────
# Choose: "gemini" or "ollama"
LLM_BACKEND=gemini

# ── Gemini ─────────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# ── Ollama (local) ─────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Paths ──────────────────────────────────────────────────────────────────────
SPIDER_DATA_PATH=data/spider
COSQL_DATA_PATH=data/cosql
RESULTS_DIR=results
